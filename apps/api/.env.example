# dev นอก docker — copy เป็น .env (prisma + server อ่านจากไฟล์นี้)
# หมายเหตุ: compose ไม่เปิด port db ออกมา — dev นอก docker ต้องรัน postgres เอง
# หรือเพิ่ม ports "5432:5432" ให้ service db ชั่วคราว
DATABASE_URL=postgresql://beconnected:changeme@localhost:5432/erp
JWT_SECRET=changeme-random-อย่างน้อย-32-ตัวอักษร
WEB_ORIGIN=http://localhost:3000
API_PORT=4000
