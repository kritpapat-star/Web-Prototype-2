# สำหรับ docker compose — copy เป็น .env แล้วเติมค่าจริง (ห้าม commit .env)
DB_PASSWORD=changeme
# สุ่มใหม่ก่อนขึ้น production: openssl rand -base64 48
# api ไม่ยอม start ถ้าสั้นกว่า 32 ตัวอักษรหรือยังเป็นค่า changeme (guard ใน apps/api/src/lib/env.ts)
JWT_SECRET=changeme-random-อย่างน้อย-32-ตัวอักษร
# origin ของหน้าเว็บที่ browser ใช้ (CORS ฝั่ง api) — production บังคับตั้ง ไม่มี fallback
WEB_ORIGIN=http://localhost:3000
# URL ของ api ที่ "browser" มองเห็น — ถูก bake ตอน build web (build arg)
PUBLIC_API_URL=http://localhost:4000/trpc
# รหัสผ่านเริ่มต้นตอนรัน seed ครั้งแรกบน production (dev ไม่ต้องตั้ง — ใช้รหัส dev ใน seed.ts)
# หลัง seed แล้วเปลี่ยนรายคนด้วย: pnpm user:password <username> <รหัสใหม่>
SEED_PASSWORD=
